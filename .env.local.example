# ============================================================
# MR. CLEANER — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.local and fill in your values.
# ============================================================

# AI Engine — Gemini (Primary, Free Tier Available)
# Get your key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# AI Engine — DeepSeek (Optional, ~$0.01/conversation)
DEEPSEEK_API_KEY=

# AI Engine — OpenAI (Optional, ~$0.03/conversation)
OPENAI_API_KEY=

# Supabase — Required for persistent data
# Create free project: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Calendar — Optional (availability sync)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# Twilio — Optional (SMS alerts, simulated without key)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Business Config
BUSINESS_NAME="Mr. Cleaner Mobile Detailing"
BUSINESS_OWNER="Owner"
BUSINESS_LOCATION="Texas"
BUSINESS_TIMEZONE="America/Chicago"
BUSINESS_PHONE="+15550001234"
WHATSAPP_NUMBER="+15550001234"
FB_MESSENGER_URL=

# Dashboard Auth — REQUIRED for dashboard access
# Password: any strong string
DASHBOARD_PASSWORD=
# Session secret: generate with openssl rand -hex 32 (min 32 chars)
DASHBOARD_SESSION_SECRET=

# Stripe — Optional (payment collection)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App URL — Update for production
NEXT_PUBLIC_APP_URL=http://localhost:3000
